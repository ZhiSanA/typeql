{
  "compilerOptions": {
    "lib": ["ES2022"],
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": true,
    "rootDir": "src",
    "types": ["node"],
    "declaration": true,
    "paths": {
      "typeorm/metadata/*": ["./node_modules/typeorm/metadata/*"]
    }
  },
  "include": ["src"]
}
